{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/researchkb-agent-memory/claim.schema.json",
  "title": "Claim",
  "type": "object",
  "required": ["claim_id", "claim_type", "statement"],
  "properties": {
    "claim_id": { "type": "string", "minLength": 1 },
    "claim_type": {
      "type": "string",
      "enum": ["method", "experiment", "limitation", "failure", "safety", "future_work", "result"]
    },
    "statement": { "type": "string", "minLength": 1 },
    "paper_id": { "type": ["string", "null"] },
    "chunk_id": { "type": ["string", "null"] },
    "confidence": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "created_by": {
      "type": ["string", "null"],
      "enum": ["human", "llm", "script", null]
    }
  },
  "additionalProperties": true
}
