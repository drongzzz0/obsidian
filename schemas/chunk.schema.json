{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/researchkb-agent-memory/chunk.schema.json",
  "title": "Chunk",
  "type": "object",
  "required": ["chunk_id", "source_type", "text"],
  "properties": {
    "chunk_id": { "type": "string", "minLength": 1 },
    "paper_id": { "type": ["string", "null"] },
    "source_type": {
      "type": "string",
      "enum": ["paper_text", "abstract", "appendix", "table", "human_note", "web_page"]
    },
    "section": { "type": ["string", "null"] },
    "locator": { "type": ["string", "null"] },
    "text": { "type": "string", "minLength": 1 },
    "embedding_ref": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
